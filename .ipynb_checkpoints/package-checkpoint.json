{
  "name": "udagram-deployment",
  "version": "1.0.0",
  "scripts": {
    "frontend:install": "cd udagram-frontend && npm install -f",
    "frontend:build": "cd udagram-frontend && npm run build",
    "frontend:lint": "cd udagram-frontend && npm run lint",
    "frontend:deploy": "cd udagram-frontend && npm run build && ./bin/deploy.sh",

    "backend:install": "cd udagram-api && npm install .",
    "backend:build": "cd udagram-api && npm run build",
    "backend:deploy": "cd udagram-api && npm run deploy",

    "build": "npm run frontend:install && npm run backend:install && npm run frontend:build && npm run backend:build",

    "deploy": "npm run frontend:deploy && npm run backend:deploy"
  }
}